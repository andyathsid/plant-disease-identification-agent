  ISSN = {1573-7462},
  JOURNALTITLE = {Artificial Intelligence Review},
  KEYWORDS = {Computer vision,Deep learning,Generative adversarial networks,Plant diseases detection,Vision language models,Vision transformers},
  LANGID = {english},
  NUMBER = {3},
  PAGES = {92},
  SHORTJOURNAL = {Artif Intell Rev},
