  KEYWORDS = {Computer Science - Artificial Intelligence,Computer Science - Information Retrieval,Computer Science - Multiagent Systems},
  PUBSTATE = {prepublished},
  SHORTTITLE = {Parallelism {{Meets Adaptiveness}}},
