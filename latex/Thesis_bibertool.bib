  FILE = {C:\Users\Andakara\Zotero\storage\P9ULSSJR\Ahmad et al. - 2023 - A survey on using deep learning techniques for plant disease diagnosis and recommendations for devel.pdf},
  ISSN = {27723755},
  JOURNALTITLE = {Smart Agricultural Technology},
  LANGID = {english},
  PAGES = {100083},
  SHORTJOURNAL = {Smart Agricultural Technology},
