  DOI = {10.1038/s41598-025-92143-0},
  FILE = {C:\Users\Andakara\Zotero\storage\V8T6TUDQ\Alhwaiti et al. - 2025 - Leveraging YOLO deep learning models to enhance plant disease identification.pdf},
  ISSN = {2045-2322},
  JOURNALTITLE = {Scientific Reports},
  KEYWORDS = {Computational biology and bioinformatics,Computational models,Image processing,Machine learning},
  LANGID = {english},
  NUMBER = {1},
