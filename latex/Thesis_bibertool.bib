  KEYWORDS = {Computer Science - Computer Vision and Pattern Recognition},
  PUBSTATE = {prepublished},
  TITLE = {Benchmarking {{In-the-wild Multimodal Disease Recognition}} and {{A Versatile Baseline}}},
  URLDATE = {2025-12-27},
